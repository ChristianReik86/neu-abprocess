# Datenbank – PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/abprocess?schema=public"

# NextAuth – zufälligen Wert generieren: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="HIER_SICHEREN_ZUFALLSWERT_EINTRAGEN"

# Stripe – Keys aus dem Stripe-Dashboard (Test-Modus: sk_test_...)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs – nach Ausführen von scripts/setup-stripe.sh eintragen
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_BUSINESS="price_..."
STRIPE_PRICE_PROFESSIONAL="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# App-URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
